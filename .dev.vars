# Local development and test-only placeholder values — never used against a
# real Cloudflare account. wrangler and @cloudflare/vitest-pool-workers load
# this file automatically for `wrangler dev` and `npm run test:workers`.
# Production secrets are set with `wrangler secret put` and never live here.
NETWORK_SESSION_SECRET=dev-only-network-session-secret-not-for-production
OPAQUE_USER_ID_SECRET=dev-only-opaque-user-id-secret-not-for-production
